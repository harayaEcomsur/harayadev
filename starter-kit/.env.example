# Google AI Studio (https://aistudio.google.com/apikey) tiene tier gratuito.
GEMINI_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Solo para la demo pública con datos ficticios: cualquier valor no vacío agrega
# <meta name="robots" content="noindex"> a todo el sitio. NO definir en sitios
# de clientes reales.
SITE_NOINDEX=

# --- Asistente IA en WhatsApp (módulo opcional; ver README) ---
# Si faltan, el webhook /api/whatsapp responde 200 sin hacer nada (inofensivo).
# Token secreto inventado por ti, repetido al registrar el webhook en Meta:
WHATSAPP_VERIFY_TOKEN=
# Token permanente (System User) de la app de Meta del cliente:
WHATSAPP_TOKEN=
# ID del número en WhatsApp Manager (no es el número de teléfono):
WHATSAPP_PHONE_NUMBER_ID=
