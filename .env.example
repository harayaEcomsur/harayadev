RESEND_API_KEY=
CONTACT_TO_EMAIL=
# Remitente de los avisos (contacto y contratos). Requiere dominio verificado en
# Resend (ej. "HarayaDev <contacto@haraya.dev>"). Si falta, usa onboarding@resend.dev,
# que solo puede enviar al email dueño de la cuenta Resend.
EMAIL_FROM=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Requerido para el chat IA (widget flotante en todo el sitio). Si falta, el
# widget muestra un mensaje de error amigable en vez de fallar en silencio.
# Google AI Studio (https://aistudio.google.com/apikey) tiene tier gratuito.
GEMINI_API_KEY=
# Formato E.164 sin "+" ni espacios (ej. 56912345678). Si se deja vacío, el
# link/botón de WhatsApp simplemente no se muestra.
WHATSAPP_NUMBER=

# --- Contratos (/contratar) ---
# RUT de la EIRL mostrado en el contrato. Si falta, el documento dice "[RUT por completar]".
COMPANY_RUT=
# Datos de la cuenta para transferencias, mostrados en el contrato generado. Si faltan
# BANK_NAME o BANK_ACCOUNT_NUMBER, el contrato indica que los datos se envían por
# WhatsApp/email al confirmar (el flujo funciona igual).
BANK_NAME=
BANK_ACCOUNT_TYPE=
BANK_ACCOUNT_NUMBER=
BANK_HOLDER=
BANK_RUT=
BANK_EMAIL=
